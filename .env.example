# =========================================================
# KENNYGAMES — variables d'environnement (TEMPLATE, sans valeurs)
# Copier en `.env.local` et remplir. NE JAMAIS committer .env.local.
# =========================================================

# ---- Supabase (public, cote client) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Supabase (SERVEUR UNIQUEMENT — jamais dans le bundle client) ----
SUPABASE_SERVICE_ROLE_KEY=

# ---- Madame Irma / IA (SERVEUR UNIQUEMENT) ----
ANTHROPIC_API_KEY=
# Modele Claude utilise par Madame Irma (defaut : claude-opus-4-8)
MADAME_IRMA_MODEL=claude-opus-4-8

# ---- Stripe (V2, SERVEUR UNIQUEMENT) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Secret partage pour proteger les routes cron (genere une valeur aleatoire) ----
CRON_SECRET=

# =========================================================
# Config produit (public, modifiable sans migration)
# Le nom de l'app et de la monnaie sont des placeholders : decision au mockup.
# =========================================================
NEXT_PUBLIC_APP_NAME=KennyGames
NEXT_PUBLIC_CURRENCY_NAME=Pépites
NEXT_PUBLIC_MASCOT_NAME=Tata Kenny

# Economie — le rake est le regulateur anti-inflation (§6). En basis points.
RAKE_BPS=400
# Dotation initiale a l'onboarding (jetons)
INITIAL_GRANT=1000
# Coffre journalier / recompense de streak de base
DAILY_CHEST_AMOUNT=100
# Cout de creation d'un marche (sink anti-spam)
MARKET_CREATION_COST=50
